# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env ขึ้น git)

# พอร์ตที่ server รัน — Render จะ set ค่านี้ให้เองอัตโนมัติตอน deploy จริง
PORT=2567

# MongoDB Atlas connection string
# เอามาจาก Atlas Dashboard > Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# สุ่มสตริงยาวๆ สำหรับเซ็น JWT — ห้ามใช้ค่าเดียวกับตัวอย่าง
# สร้างได้ด้วยคำสั่ง: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-string-before-deploying

# Origin ของ client ที่ deploy แล้ว (สำหรับ CORS) — ใส่หลัง deploy client เสร็จ
# ใส่ได้หลายค่าคั่นด้วย comma เช่น https://app.vercel.app,https://my-domain.com
FRONTEND_URL=https://your-app.vercel.app
