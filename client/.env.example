# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (สำหรับ dev local)
# ตอน deploy จริงบน Vercel ให้ไปตั้งค่านี้ใน Vercel Dashboard > Settings > Environment Variables แทน

# URL ของ Colyseus server ที่ deploy แล้ว (WebSocket)
# ตัวอย่างหลัง deploy บน Render: wss://cardgame-server-xxxx.onrender.com
VITE_SERVER_URL=ws://localhost:2567
